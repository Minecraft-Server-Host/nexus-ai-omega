# ============================================================
# Nexus AI Omega v3.3 — Environment Variables
# Copy to .env — NEVER commit .env to git!
# ============================================================

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── Discord ────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_PUBLIC_KEY=your-discord-public-key
NEXUS_CONTROL_GUILD_ID=1523481048149921883

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nexus_omega?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/nexus_omega?sslmode=require
REDIS_URL=redis://default:password@host:6379

# ── Analytics & Search ─────────────────────────────────────
KAFKA_BROKERS=localhost:9092
CLICKHOUSE_URL=http://localhost:8123
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Security ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
# Generate: openssl rand -hex 16  (exactly 32 bytes for AES-256)
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_HEX

OAUTH_REDIRECT_URI=https://api.nexus-omega.up.railway.app/auth/discord/callback
DASHBOARD_URL=https://nexus-omega.up.railway.app

# ── AI Providers — add any/all you have keys for ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GROK_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_VERSION=2024-02-01
OLLAMA_BASE_URL=http://localhost:11434

# AI Config
AI_PROVIDER=auto
AI_MODEL_PRIMARY=gpt-4o
AI_MODEL_FALLBACK=claude-3-5-sonnet-20241022
AI_AUTO_FAILOVER=true
AI_COST_OPTIMIZER=true
AI_LOAD_BALANCE=true

# ── S3 / R2 (optional — audit media archiving) ─────────────
S3_ENDPOINT=
S3_BUCKET=nexus-omega-vault
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# ── Observability ──────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ── Feature Flags ──────────────────────────────────────────
FEATURE_AI_COMMUNITY_MANAGER=true
FEATURE_ZERO_TRUST=true
FEATURE_WASM_PLUGINS=true
FEATURE_VOICE_AI=true
FEATURE_LAVALINK=true
FEATURE_UNIVERSAL_AI=true
FEATURE_BYO_KEY=true

# ── Lavalink (optional) ────────────────────────────────────
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ── Arweave (optional) ─────────────────────────────────────
ARWEAVE_KEY=
