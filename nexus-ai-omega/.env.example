# ══════════════════════════════════════════════════════════════════
# Nexus AI Omega v5.1 — Konfiguration
# ══════════════════════════════════════════════════════════════════
# 1. Diese Datei kopieren:  cp .env.example .env
# 2. .env ausfüllen (minimum: DISCORD_TOKEN + DISCORD_CLIENT_ID)
# 3. Bot starten:           npm run dev
# ══════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ── Discord (PFLICHT) ──────────────────────────────────────────────
# Bot-Token: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=dein-discord-bot-token-hier

# Client-ID: https://discord.com/developers/applications → Allgemein
DISCORD_CLIENT_ID=1523530214938771546

DISCORD_CLIENT_SECRET=dein-discord-client-secret
DISCORD_PUBLIC_KEY=dein-discord-public-key

# Nexus Control Server (für globale Admin-Commands)
NEXUS_CONTROL_GUILD_ID=1523481048149921883
NEXUS_TEAM_ROLE_IDS=

# ── KI-Provider (MINDESTENS EINEN eintragen für echte KI-Antworten) ──
# ⭐ EMPFEHLUNG 1: Groq — kostenlos, sehr schnell
# Kostenloser Key: https://console.groq.com/keys
GROQ_API_KEY=

# ⭐ EMPFEHLUNG 2: Google Gemini — kostenlos bis 60 req/min
# Kostenloser Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Weitere Provider (alle optional):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_VERSION=2024-06-01
OLLAMA_BASE_URL=http://localhost:11434

# Ohne Key: Bot läuft mit Mock-Fallback (zeigt wie man Key einrichtet)

# ── Datenbank (OPTIONAL — SQLite wird automatisch erstellt) ────────
# Für Produktion mit vielen Servern: PostgreSQL empfohlen
# DATABASE_URL=postgresql://user:password@host:5432/nexus_omega?sslmode=require

# ── Redis (OPTIONAL — Memory-Fallback wenn nicht verfügbar) ───────
REDIS_URL=redis://localhost:6379

# ── Sicherheit ─────────────────────────────────────────────────────
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=aendere-mich-zu-einem-langen-zufaelligen-string
SESSION_SECRET=aendere-mich-zu-einem-anderen-langen-string
ENCRYPTION_KEY=aendere-mich-zu-einem-32-zeichen-string
SECURITY_SALT=nexus-omega-v5-salt-change-me

# CORS-erlaubte Origins (kommagetrennt)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

OAUTH_REDIRECT_URI=http://localhost:8080/auth/discord/callback
DASHBOARD_URL=http://localhost:8080

# ── Analytics (alle optional) ─────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexus-omega-v5
KAFKA_SSL=false
CLICKHOUSE_URL=http://localhost:8123
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── S3/R2 Archivierung (optional) ─────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=nexus-omega-vault
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto


# ── Musik-System ───────────────────────────────────────────────────
# YouTube Cookie (optional — verhindert 429-Fehler bei vielen Anfragen)
YOUTUBE_COOKIE=
# Spotify Links (optional) → https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# ── Feature Flags ──────────────────────────────────────────────────
FEATURE_ZERO_TRUST=true
FEATURE_UNIVERSAL_AI=true
FEATURE_BYO_KEY=true
FEATURE_LEVELING=true
FEATURE_ECONOMY=true
FEATURE_VOICE_AI=true

# ── Shard-Konfiguration ────────────────────────────────────────────
SHARD_COUNT=auto
