{
  "name": "nexus-ai-omega",
  "version": "5.0.0",
  "description": "🌐 Nexus AI Omega v5 — Premium AI-Powered Discord Platform • Zero-Trust • 20 AI Modules • 14 LLM Providers • Global Admin Control Center • Production Ready",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:bot": "tsx watch src/bot/client.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --fix",
    "lint:check": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "worker:core": "WORKER_ROLE=core node dist/services/workers.js",
    "worker:security": "WORKER_ROLE=security node dist/services/workers.js",
    "worker:ai": "WORKER_ROLE=ai node dist/services/workers.js",
    "worker:analytics": "WORKER_ROLE=analytics node dist/services/workers.js",
    "docker:build": "docker build -t nexus-ai-omega:v5 .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.0",
    "@mistralai/mistralai": "^2.4.1",
    "@prisma/client": "5.22.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "axios": "^1.7.7",
    "@discordjs/voice": "^0.17.0",
    "play-dl": "^1.9.7",
    "better-sqlite3": "^9.4.3",
    "bullmq": "^5.31.0",
    "clickhouse": "^2.6.0",
    "cohere-ai": "^7.15.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "kafkajs": "^2.2.4",
    "lru-cache": "^11.0.2",
    "openai": "^4.73.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prisma": "5.22.0",
    "redis": "^5.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
