{
  "name": "nexus-ai-omega",
  "version": "3.3.0-team-v2",
  "description": "🌐 Nexus AI Omega v3.3 — World's Best Discord Bot • Zero-Trust • 18 AI Modules • 13 LLM Providers Universal • Global Admin Control Center",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "worker:core": "WORKER_ROLE=core node dist/services/workers.js",
    "worker:security": "WORKER_ROLE=security node dist/services/workers.js",
    "worker:ai": "WORKER_ROLE=ai node dist/services/workers.js",
    "worker:analytics": "WORKER_ROLE=analytics node dist/services/workers.js",
    "lint": "echo 'Lint check — eslint not yet configured; add eslint to devDependencies to enable' && exit 0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "axios": "^1.7.7",
    "bullmq": "^5.31.0",
    "clickhouse": "^2.6.0",
    "cohere-ai": "^7.15.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "mistralai": "^1.3.5",
    "openai": "^4.73.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
